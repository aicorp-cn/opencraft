# ===========================================
# OpenCraft Python Backend 配置文件
# ===========================================

# 服务器配置
HOST=0.0.0.0
PORT=3000

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./cache.db

# ===========================================
# LLM 配置 - 支持 OpenAI 兼容协议
# ===========================================
# 通过修改 LLM_BASE_URL 和 LLM_MODEL 切换不同提供商

# 方式一: 使用 LLM_ 前缀配置 (推荐)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o-mini

# 方式二: 使用旧配置 (向后兼容)
# OPENAI_API_KEY=sk-your-api-key-here
# OPENAI_MODEL=gpt-4o-mini

# ===========================================
# 各提供商配置示例
# ===========================================

# OpenAI (官方)
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-xxx
# LLM_MODEL=gpt-4o-mini

# DeepSeek (国产，性价比高)
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=sk-xxx
# LLM_MODEL=deepseek-chat

# 智谱 AI (GLM 系列)
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_API_KEY=xxx.xxx
# LLM_MODEL=glm-4-flash

# Moonshot (月之暗面，长上下文)
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_API_KEY=sk-xxx
# LLM_MODEL=moonshot-v1-8k

# 硅基流动 (多模型聚合)
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# LLM_API_KEY=sk-xxx
# LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# 本地 Ollama (需启用 OpenAI 兼容模式: OLLAMA_ORIGINS=* ollama serve)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3

# 本地 vLLM
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=token-abc123
# LLM_MODEL=meta-llama/Llama-3-8b-chat-hf

# ===========================================
# 其他配置
# ===========================================

