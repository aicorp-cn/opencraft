# ===========================================
# OpenCraft - 根目录 Git 忽略配置
# ===========================================

# 依赖目录
node_modules/
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/

# 构建产物
dist/
build/
*.egg-info/

# 环境变量（包含敏感信息）
.env
.env.local
.env.*.local

# 数据库文件
*.db
*.sqlite
*.sqlite3

# IDE 和编辑器
.idea/
.vscode/
*.swp
*.swo
*~

# 系统文件
.DS_Store
Thumbs.db
*.log

# 测试覆盖率
.coverage
htmlcov/
.pytest_cache/

# 临时文件
*.tmp
*.temp
.cache/